@model IEnumerable<Mist452SmithMayka.Models.Listing>

@{
    ViewData["Title"] = "Order Confirmation";
}

<h1 class="mb-2">Order Confirmed!</h1>
<p class="text-muted mb-4">Thank you for your purchase. Here's a summary of what you ordered.</p>

<table class="table">
    <thead>
        <tr>
            <th>Item</th>
            <th>Seller</th>
            <th>Price</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Seller?.UserName</td>
                <td>@item.Price.ToString("C")</td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <td colspan="2" class="fw-bold text-end">Total</td>
            <td class="fw-bold">@Model.Sum(l => l.Price).ToString("C")</td>
        </tr>
    </tfoot>
</table>

<a asp-controller="Account" asp-action="Details" class="btn btn-primary">View Order History</a>
<a asp-controller="Listings" asp-action="Index" class="btn btn-outline-secondary ms-2">Continue Shopping</a>
